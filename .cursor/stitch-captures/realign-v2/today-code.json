{"screenId":"cf9c0f524fa344e9add8976752ec7e81","projectId":"12603776243583345396","htmlContent":"<!DOCTYPE html>\n\n<html data-theme=\"realign\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1\" name=\"viewport\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Merriweather:ital,wght@0,400;0,700;1,400&amp;family=Public+Sans:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/>\n<style>\n    :root {\n      --font-size: 16px;\n      --font-weight-medium: 500;\n      --font-weight-normal: 400;\n      --radius: .75rem;\n      --nav-control-height: 56px;\n      --nav-control-padding-y: 8px;\n      --nav-control-font-size: 12px;\n      --nav-control-label-font-size: 11px;\n      --nav-control-icon-size: 20px;\n      --nav-control-gap: 4px;\n\n      /* Realign Ministries Theme */\n      --background: #FFF5F0;\n      --foreground: #1A1A1A;\n      --card: #ffffff;\n      --card-foreground: #1A1A1A;\n      --popover: #ffffff;\n      --popover-foreground: #1A1A1A;\n      --primary: #D91F26;\n      --primary-foreground: #ffffff;\n      --secondary: #FFE8DC;\n      --secondary-foreground: #1A1A1A;\n      --muted: #FFE8DC;\n      --muted-foreground: #665c56;\n      --accent: #F28C00;\n      --accent-foreground: #ffffff;\n      --destructive: #dc2626;\n      --destructive-foreground: #ffffff;\n      --border: rgba(26, 26, 26, 0.1);\n      --input: transparent;\n      --input-background: #FFE8DC;\n      --switch-background: #cbd5e1;\n      --ring: rgba(217, 31, 38, .3);\n      --sidebar: #ffffff;\n      --sidebar-foreground: #1A1A1A;\n      --sidebar-primary: #D91F26;\n      --sidebar-primary-foreground: #ffffff;\n      --sidebar-accent: #FFE8DC;\n      --sidebar-accent-foreground: #1A1A1A;\n      --sidebar-border: rgba(26, 26, 26, 0.1);\n      --sidebar-ring: rgba(217, 31, 38, .3);\n\n      --canvas-gradient: linear-gradient(180deg, var(--background) 0%, #fffcfb 100%);\n      --surface-gradient: linear-gradient(140deg, var(--card) 0%, var(--secondary) 100%);\n      --surface-gradient-soft: linear-gradient(140deg, var(--card) 0%, rgba(255, 232, 220, 0.4) 100%);\n      --surface-glass-gradient: linear-gradient(160deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 232, 220, 0.8) 100%);\n      --brand-gradient: linear-gradient(to right, #D91F26, #F28C00);\n    }\n\n    body {\n      background-color: var(--background);\n      color: var(--foreground);\n      font-family: 'Inter', sans-serif;\n      -webkit-font-smoothing: antialiased;\n    }\n\n    .scripture-text {\n      font-family: 'Merriweather', serif;\n    }\n\n    /* [project]/components/BottomNavigation.module.css */\n    .BottomNavigation-shell {\n      pointer-events: auto;\n      border: 1px solid var(--border);\n      background: rgba(255, 255, 255, 0.95);\n      backdrop-filter: blur(18px);\n      border-radius: 24px;\n      width: min(100%, 36rem);\n      overflow: hidden;\n      box-shadow: 0 24px 48px rgba(26, 26, 26, 0.15);\n    }\n\n    .BottomNavigation-navButton {\n      min-height: 56px;\n      width: 100%;\n      padding: 8px 0;\n      color: var(--muted-foreground);\n      font-size: 11px;\n      flex-direction: column;\n      flex: 1;\n      justify-content: center;\n      align-items: center;\n      transition: color .2s;\n      display: flex;\n      position: relative;\n    }\n\n    .BottomNavigation-navButtonActive {\n      color: var(--primary);\n    }\n\n    .BottomNavigation-activeIndicator {\n      background: var(--brand-gradient);\n      opacity: 0.15;\n      border-radius: 14px;\n      position: absolute;\n      top: 4px;\n      bottom: 4px;\n      left: 8px;\n      right: 8px;\n    }\n\n    /* [project]/components/HomeScreen.module.css overrides */\n    .page-container {\n      background: var(--canvas-gradient);\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .verse-card {\n      border: 1px solid rgba(217, 31, 38, 0.2);\n      background: var(--surface-gradient);\n      box-shadow: 0 16px 24px rgba(217, 31, 38, 0.08);\n    }\n\n    .quick-card {\n      border: 1px solid var(--border);\n      background: var(--surface-gradient-soft);\n      transition: all 0.2s ease;\n    }\n\n    .quick-card:hover {\n      background: var(--surface-gradient);\n      transform: translateY(-2px);\n      box-shadow: 0 12px 24px rgba(26, 26, 26, 0.1);\n    }\n\n    .progress-bar-indicator {\n      background: var(--primary);\n    }\n  </style>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"primary\": \"#D91F26\",\n            \"background-light\": \"#FFF5F0\",\n            \"background-dark\": \"#1A1A1A\",\n          },\n          fontFamily: {\n            \"display\": [\"Public Sans\", \"sans-serif\"],\n            \"serif\": [\"Merriweather\", \"serif\"]\n          },\n          borderRadius: { \"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\" },\n        },\n      },\n    }\n  </script>\n</head>\n<body class=\"antialiased\">\n<div class=\"page-container\" style=\"--bottom-nav-height:104px\">\n<!-- App Surface -->\n<div class=\"flex-1 flex justify-center p-4 sm:p-6 md:p-8 pb-32\">\n<div class=\"w-full max-w-2xl bg-white/80 rounded-[28px] border border-[var(--border)] shadow-xl overflow-hidden flex flex-col relative\">\n<!-- Header area with tagline and logo -->\n<div class=\"p-6 pb-0 flex flex-col gap-2\">\n<div class=\"flex justify-between items-start\">\n<div>\n<h1 class=\"text-2xl font-bold text-[var(--primary)]\">Welcome back</h1>\n<p class=\"text-sm text-[var(--muted-foreground)]\">Stay rooted in Scripture today</p>\n<p class=\"text-[10px] uppercase tracking-wider text-[var(--muted-foreground)] opacity-70 mt-1\">\n                Scripture • Wisdom • Order • Reflection • Devotion\n              </p>\n</div>\n<button class=\"bg-[var(--secondary)] p-2 px-4 rounded-xl text-xs font-bold text-[var(--primary)] flex items-center gap-2 border border-[var(--border)]\">\n              NIV\n              <svg class=\"lucide lucide-user\" fill=\"none\" height=\"16\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"16\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg>\n</button>\n</div>\n</div>\n<div class=\"flex-1 p-6 space-y-6 overflow-y-auto\">\n<!-- Verse of the Day Card -->\n<div class=\"verse-card p-6 rounded-xl flex flex-col gap-4\">\n<div class=\"flex items-center gap-2 text-[var(--primary)]\">\n<svg class=\"lucide lucide-calendar\" fill=\"none\" height=\"18\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"18\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect height=\"18\" rx=\"2\" width=\"18\" x=\"3\" y=\"4\"></rect><path d=\"M3 10h18\"></path></svg>\n<span class=\"text-sm font-semibold\">Verse of the day</span>\n</div>\n<div class=\"space-y-2\">\n<blockquote class=\"scripture-text text-lg italic text-[var(--foreground)] leading-relaxed\">\n                “Do not conform to the pattern of this world, but be transformed by the renewing of your mind.”\n              </blockquote>\n<cite class=\"text-sm font-medium text-[var(--primary)] block\">— Romans 12:2</cite>\n</div>\n</div>\n<!-- Quick Access Grid -->\n<div class=\"space-y-4\">\n<h2 class=\"text-lg font-semibold text-[var(--foreground)]\">Continue your journey</h2>\n<div class=\"grid grid-cols-2 gap-3\">\n<!-- Open Scripture -->\n<div class=\"quick-card p-4 rounded-xl flex flex-col gap-3 cursor-pointer\">\n<svg class=\"text-[var(--primary)]\" fill=\"none\" height=\"24\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg>\n<div class=\"space-y-1\">\n<h4 class=\"text-sm font-semibold\">Open Scripture</h4>\n<p class=\"text-[10px] text-[var(--muted-foreground)] leading-tight\">Return to the passage you were studying.</p>\n</div>\n</div>\n<!-- Marked -->\n<div class=\"quick-card p-4 rounded-xl flex flex-col gap-3 cursor-pointer\">\n<svg class=\"text-[var(--primary)]\" fill=\"none\" height=\"24\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg>\n<div class=\"space-y-1\">\n<h4 class=\"text-sm font-semibold\">Marked</h4>\n<p class=\"text-[10px] text-[var(--muted-foreground)] leading-tight\">Review verses you marked.</p>\n</div>\n</div>\n<!-- Reflections -->\n<div class=\"quick-card p-4 rounded-xl flex flex-col gap-3 cursor-pointer\">\n<svg class=\"text-[var(--primary)]\" fill=\"none\" height=\"24\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg>\n<div class=\"space-y-1\">\n<h4 class=\"text-sm font-semibold\">Reflections</h4>\n<p class=\"text-[10px] text-[var(--muted-foreground)] leading-tight\">Capture insights in one place.</p>\n</div>\n</div>\n<!-- Memory -->\n<div class=\"quick-card p-4 rounded-xl flex flex-col gap-3 cursor-pointer\">\n<svg class=\"text-[var(--primary)]\" fill=\"none\" height=\"24\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"24\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z\"></path><path d=\"M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z\"></path><path d=\"M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4\"></path></svg>\n<div class=\"space-y-1\">\n<h4 class=\"text-sm font-semibold\">Memory</h4>\n<p class=\"text-[10px] text-[var(--muted-foreground)] leading-tight\">Strengthen your recall.</p>\n</div>\n</div>\n</div>\n</div>\n<!-- Stats Section -->\n<div class=\"bg-white border border-[var(--border)] rounded-xl p-6 space-y-4 shadow-sm\">\n<h3 class=\"text-sm font-semibold flex items-center gap-2 text-[var(--foreground)]\">\n<svg class=\"text-[var(--primary)]\" fill=\"none\" height=\"16\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"16\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>\n              Rhythm overview\n            </h3>\n<div class=\"space-y-4\">\n<div class=\"space-y-2\">\n<div class=\"flex justify-between text-xs\">\n<span class=\"text-[var(--muted-foreground)]\">Reflections captured</span>\n<span class=\"font-semibold\">42%</span>\n</div>\n<div class=\"h-2 w-full bg-[var(--secondary)] rounded-full overflow-hidden\">\n<div class=\"h-full bg-[var(--primary)] rounded-full\" style=\"width: 42%\"></div>\n</div>\n</div>\n<div class=\"space-y-2\">\n<div class=\"flex justify-between text-xs\">\n<span class=\"text-[var(--muted-foreground)]\">Marked verses</span>\n<span class=\"font-semibold\">35%</span>\n</div>\n<div class=\"h-2 w-full bg-[var(--secondary)] rounded-full overflow-hidden\">\n<div class=\"h-full bg-[var(--primary)] rounded-full\" style=\"width: 35%\"></div>\n</div>\n</div>\n</div>\n</div>\n<!-- Recent Reflections -->\n<div class=\"bg-white border border-[var(--border)] rounded-xl p-6 space-y-4 shadow-sm\">\n<h3 class=\"text-sm font-semibold text-[var(--foreground)]\">Recent reflections</h3>\n<div class=\"space-y-4\">\n<div class=\"border-l-2 border-[var(--primary)] pl-3 py-1\">\n<p class=\"text-[10px] text-[var(--primary)] font-bold\">Philippians 3:12-14 • Jul 8</p>\n<p class=\"text-sm text-[var(--foreground)] mt-1\">Pressing on toward the goal — what does it mean to forget what is behind?</p>\n</div>\n<div class=\"border-l-2 border-[var(--primary)] pl-3 py-1\">\n<p class=\"text-[10px] text-[var(--primary)] font-bold\">Romans 12:2 • Jul 6</p>\n<p class=\"text-sm text-[var(--foreground)] mt-1\">Do not conform to the pattern of this world… transformation starts with the mind.</p>\n</div>\n</div>\n</div>\n<!-- Footer credit -->\n<div class=\"text-center pt-4 opacity-50\">\n<p class=\"text-[10px] font-medium text-[var(--muted-foreground)] uppercase tracking-widest\">Realign Ministries</p>\n</div>\n</div>\n</div>\n</div>\n<!-- Bottom Navigation -->\n<div class=\"fixed bottom-0 left-0 right-0 z-50 flex justify-center p-4 px-6 pb-[calc(env(safe-area-inset-bottom)+20px)] pointer-events-none\">\n<div class=\"BottomNavigation-shell\">\n<div class=\"flex items-center justify-around p-2 gap-2\">\n<!-- Today -->\n<button aria-label=\"Today\" class=\"BottomNavigation-navButton BottomNavigation-navButtonActive\" type=\"button\">\n<div class=\"relative flex items-center justify-center\">\n<svg class=\"lucide lucide-house\" fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8\"></path><path d=\"M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"></path></svg>\n<div class=\"BottomNavigation-activeIndicator\"></div>\n</div>\n<span class=\"mt-1 font-semibold\">Today</span>\n</button>\n<!-- Scripture -->\n<button aria-label=\"Scripture\" class=\"BottomNavigation-navButton\" type=\"button\">\n<div class=\"flex items-center justify-center\">\n<svg class=\"lucide lucide-book-open\" fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 7v14\"></path><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"></path></svg>\n</div>\n<span class=\"mt-1\">Scripture</span>\n</button>\n<!-- Reflections -->\n<button aria-label=\"Reflections\" class=\"BottomNavigation-navButton\" type=\"button\">\n<div class=\"flex items-center justify-center\">\n<svg class=\"lucide lucide-file-text\" fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z\"></path><path d=\"M14 2v4a2 2 0 0 0 2 2h4\"></path><path d=\"M10 9H8\"></path><path d=\"M16 13H8\"></path><path d=\"M16 17H8\"></path></svg>\n</div>\n<span class=\"mt-1\">Reflections</span>\n</button>\n<!-- Marked -->\n<button aria-label=\"Marked\" class=\"BottomNavigation-navButton\" type=\"button\">\n<div class=\"flex items-center justify-center\">\n<svg class=\"lucide lucide-heart\" fill=\"none\" height=\"20\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"20\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"></path></svg>\n</div>\n<span class=\"mt-1\">Marked</span>\n</button>\n</div>\n</div>\n</div>\n</div>\n</body></html>"}
