{"screenId":"8b6e43bda5ec445c90853ed089e42aa4","projectId":"12603776243583345396","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1\" name=\"viewport\"/>\n<title>Welcome · SWORD</title>\n<meta content=\"Realign Ministries login for SWORD: Scripture • Wisdom • Order • Reflection • Devotion\" name=\"description\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Public+Sans:wght@700&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n    tailwind.config = {\n      darkMode: \"class\",\n      theme: {\n        extend: {\n          colors: {\n            \"primary\": \"#D91F26\",\n            \"accent\": \"#F28C00\",\n            \"background-realign\": \"#FFF5F0\",\n            \"input-realign\": \"#FFE8DC\",\n            \"text-realign\": \"#1A1A1A\",\n          },\n          fontFamily: {\n            \"sans\": [\"Inter\", \"sans-serif\"],\n            \"display\": [\"Public Sans\", \"sans-serif\"]\n          },\n          borderRadius: {\n            \"DEFAULT\": \"0.25rem\",\n            \"lg\": \"0.5rem\",\n            \"xl\": \"0.75rem\",\n            \"full\": \"9999px\"\n          },\n        },\n      },\n    }\n  </script>\n<style>\n    body {\n      font-family: 'Inter', sans-serif;\n      color: #1A1A1A;\n    }\n    .display-font {\n      font-family: 'Public Sans', sans-serif;\n    }\n  </style>\n</head>\n<body class=\"antialiased bg-background-realign\">\n<div class=\"min-h-svh flex items-center justify-center p-4\">\n<div class=\"w-full max-w-[390px] mx-auto\">\n<!-- Main Container with Realign Branding -->\n<div class=\"w-full bg-white/95 rounded-[28px] border border-stone-200/60 shadow-[0_28px_60px_rgba(217,31,38,0.12)] p-8 flex flex-col gap-8 items-center relative overflow-hidden\">\n<!-- Header Section -->\n<div class=\"text-center\">\n<div class=\"w-[68px] h-[68px] rounded-full mx-auto mb-4 bg-gradient-to-br from-primary/10 to-accent/20 flex items-center justify-center border border-accent/20\">\n<!-- Keeping the SWORD logo element prominent -->\n<img alt=\"SWORD\" class=\"drop-shadow-md\" height=\"48\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDLxuZ9Lz5kHWrzbiA858S9LvKecmY1903nfdVyNjCZBqgv5zoANR06q6irh-EjdQgEAc_kaoWMSlpTjrfZ5hPVku4a28dPyWdygkQ_1mKezXOnxwTstqs4UlFjJmTnfrprv9juiwIoYw2YHQaBWKTSFMvtSFeXGMLDe3G8xjVqM4lBxDswHp5cuPkatqeOWefd2llRCr9j16gl8VAsiwTYq_oUxNcPdvztQqHYyc0T7WR7qLxOQ-tNXRp7o96ZLFOnGzIfCozAZGBs\" width=\"48\"/>\n</div>\n<h1 class=\"m-0 text-3xl font-bold tracking-[0.1em] text-text-realign display-font\">SWORD</h1>\n<p class=\"mt-2 text-[11px] font-semibold text-accent tracking-[0.16em] uppercase\">\n            Realign Ministries\n          </p>\n</div>\n<!-- Login Card Section -->\n<div class=\"w-full p-6 rounded-[22px] border border-stone-100 bg-white shadow-sm\">\n<p class=\"m-0 mb-6 text-2xl font-bold text-center text-text-realign\">Welcome</p>\n<div class=\"flex flex-col gap-4\">\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-[13px] font-semibold text-text-realign/80 ml-1\">Email</label>\n<input class=\"h-[46px] w-full rounded-xl border-stone-200 bg-input-realign/50 px-4 text-text-realign focus:ring-primary focus:border-primary transition-all\" readonly=\"\" type=\"email\" value=\"you@example.com\"/>\n</div>\n<div class=\"flex flex-col gap-1.5\">\n<label class=\"text-[13px] font-semibold text-text-realign/80 ml-1\">Password</label>\n<input class=\"h-[46px] w-full rounded-xl border-stone-200 bg-input-realign/50 px-4 text-text-realign focus:ring-primary focus:border-primary transition-all\" readonly=\"\" type=\"password\" value=\"••••••••\"/>\n</div>\n<button class=\"mt-2 h-12 w-full rounded-xl bg-primary hover:bg-primary/90 text-white font-semibold shadow-lg shadow-primary/20 transition-all active:scale-[0.98]\">\n         